# OpenAI-compatible API key for Fireworks AI
OPENAI_API_KEY=

# Local ROCm Qwen endpoint URL
LOCAL_ROCM_URL=http://localhost:8000

# Remote Fireworks AI endpoint URL
FIREWORKS_URL=https://api.fireworks.ai/v1

# RouteLLM cost threshold
ROUTE_COST_THRESHOLD=0.5

# Cache enabled flag
CACHE_ENABLED=true

# ChromaDB persistence settings
CHROMA_COLLECTION_NAME=routezero_cache
CHROMA_PERSIST_DIR=./.chromadb

# Cache similarity threshold for semantic lookup
CACHE_SIMILARITY_THRESHOLD=0.8
