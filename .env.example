# ── Cache ──────────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CHROMADB_PATH=.chromadb
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Router ─────────────────────────────────────────────────────────────
ROUTER_LOCAL_THRESHOLD=0.4
ROUTER_HEURISTIC_WEIGHT=0.3

# ── Local model (Qwen 3.x MoE on vLLM / ROCm) ─────────────────────────
LOCAL_MODEL_NAME=Qwen/Qwen3-30B-A3B
LOCAL_MODEL_ENDPOINT=http://localhost:8000/v1
LOCAL_MAX_TOKENS=1024
LOCAL_TIMEOUT_S=30.0

# ── Remote model (Fireworks AI) ────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL_ID=accounts/fireworks/models/llama-v3p1-405b-instruct
REMOTE_TIMEOUT_S=60.0

# ── Telemetry ──────────────────────────────────────────────────────────
SQLITE_PATH=metrics.db

# ── HuggingFace (optional, for faster model downloads) ─────────────────
HF_TOKEN=
