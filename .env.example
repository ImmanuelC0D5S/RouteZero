# ── Cache ──────────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CHROMADB_PATH=.chromadb
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Router ─────────────────────────────────────────────────────────────
ROUTER_LOCAL_THRESHOLD=0.4
ROUTER_HEURISTIC_WEIGHT=0.3

# ── Local model (Qwen2.5 GGUF via llama.cpp) ──────────────────────────
LOCAL_MODEL_PATH=models/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf
LOCAL_MAX_TOKENS=1024
LOCAL_TIMEOUT_S=120.0

# ── Remote model (Fireworks AI) ────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-405b-instruct
REMOTE_TIMEOUT_S=60.0

# ── Telemetry ──────────────────────────────────────────────────────────
SQLITE_PATH=metrics.db

# ── HuggingFace (optional, for faster model downloads) ─────────────────
HF_TOKEN=
