{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "autoupdate": true,

  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "sudo *": "ask",
      "pip uninstall *": "ask"
    }
  },

  "instructions": [
    "AGENTS.md"
  ],

  "plugin": [
    "oh-my-openagent",
    "envsitter-opencode"
  ],

  "mcp": {

    "context7": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },

    "filesystem": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"],
      "enabled": true
    },

    "exa": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "mcp-server-exa"],
      "env": { "EXA_API_KEY": "your-exa-key-here" },
      "enabled": true
    },

    "github": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "your-token-here" },
      "enabled": false
    },

    "playwright": {
      "type": "local",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "enabled": false
    }

  }
}